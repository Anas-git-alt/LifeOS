# ==============================================
# LifeOS Environment Variables
# Copy this file to .venv/.env and fill in values
# ==============================================

# ---- Discord ----
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here
# Comma-separated Discord user IDs allowed to approve/reject actions.
DISCORD_OWNER_IDS=

# ---- LLM Providers (at least one required) ----
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_DEFAULT_MODEL=openrouter/auto

NVIDIA_API_KEY=
NVIDIA_DEFAULT_MODEL=meta/llama-3.1-8b-instruct

GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---- Default Provider ----
DEFAULT_PROVIDER=openrouter

# ---- Prayer / Location ----
PRAYER_CITY=Casablanca
PRAYER_COUNTRY=Morocco
PRAYER_METHOD=2
TIMEZONE=Africa/Casablanca

# ---- Backend ----
LOCAL_MODE=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:////app/storage/lifeos.db
MEMORY_BACKEND=openviking
WORKSPACE_REPO_ROOT=/workspace
WORKSPACE_ARCHIVE_ROOT=/app/storage/workspace-archive
DISCORD_AUDIT_CHANNEL=
TTS_WORKER_URL=http://tts-worker:8010
TTS_REQUEST_TIMEOUT_SECONDS=45
TTS_HEALTH_TIMEOUT_SECONDS=5
TTS_DEFAULT_ENGINE=chatterbox_turbo
TTS_DEFAULT_MODEL_ID=chatterbox-turbo
TTS_ENABLE_CACHE=true
TTS_CACHE_TTL_SECONDS=300

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change_me_to_a_random_string

# ---- Retention ----
MEMORY_RETENTION_DAYS=60
AUDIT_RETENTION_DAYS=90
QUIET_HOURS_START=23:00
QUIET_HOURS_END=06:00
NUDGE_MODE=moderate

# ---- Optional Integrations ----
GITHUB_TOKEN=
GITHUB_REPO=
BRAVE_API_KEY=

# ---- OpenViking ----
OPENVIKING_ENABLED=true
OPENVIKING_BASE_URL=http://openviking:1933
# Required for full cutover. If blank, LifeOS falls back to API_SECRET_KEY for the internal
# Docker-side OpenViking root key.
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=lifeos
OPENVIKING_USER=default
OPENVIKING_SYNC_ON_STARTUP=true
OPENVIKING_EMBEDDING_PROVIDER=openai
OPENVIKING_EMBEDDING_API_KEY=
OPENVIKING_EMBEDDING_API_BASE=https://integrate.api.nvidia.com/v1
OPENVIKING_EMBEDDING_MODEL=nvidia/nv-embed-v1
OPENVIKING_EMBEDDING_DIMENSION=4096
OPENVIKING_VLM_PROVIDER=openai
OPENVIKING_VLM_API_KEY=
OPENVIKING_VLM_API_BASE=https://integrate.api.nvidia.com/v1
OPENVIKING_VLM_MODEL=z-ai/glm5

# ---- Feature Flags ----
# Set AGENCY_AGENTS_ENABLED=true to seed the 3 advisory agents (code-reviewer,
# qa-engineer, editorial-writer) on next startup.
AGENCY_AGENTS_ENABLED=false

# Set MEMORY_SUMMARISATION_ENABLED=true to refresh an OpenViking session summary
# artifact once a conversation exceeds MEMORY_SUMMARISATION_THRESHOLD messages.
MEMORY_SUMMARISATION_ENABLED=true
MEMORY_SUMMARISATION_THRESHOLD=30
