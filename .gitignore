# ==========================================
# LifeOS .gitignore — SECURITY CRITICAL
# ==========================================

# ---- Secrets (NEVER commit) ----
.venv/
.env
*.env
!.env.example

# ---- Runtime data (keep local only) ----
backend/storage/
storage/*
!storage/.gitkeep
!storage/README.md
!storage/init.sql
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.pid
*.Zone.Identifier

# ---- Python ----
__pycache__/
.pytest_cache/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
.pdf-venv/
tmp/
output/
test_folder/

# ---- Node / WebUI ----
node_modules/
webui/dist/
webui/node_modules/
.vite/

# ---- Docker ----
*.log

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
